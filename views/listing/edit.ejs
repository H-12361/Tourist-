<% layout("/layout/boilerplate") %>
<div class="container">
  <div class="row">
    <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3">  <%-- ✅ mobile full width --%>
      <br>
      <h2>Edit your listing</h2>
      <form action="/listing/<%=listing._id%>?_method=PUT" method="POST" 
            class="needs-validation" novalidate enctype="multipart/form-data">
        
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input type="text" name="listing[title]" required class="form-control" 
                 value="<%= listing.title %>">
          <div class="invalid-feedback">Title must be filled</div>
        </div>

        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea name="listing[description]" required class="form-control">
            <%= listing.description %>
          </textarea>
          <div class="invalid-feedback">Description is required</div>
        </div>

        <div class="mb-3">
          <label class="form-label">Original Image</label><br>
          <img src="<%= originalImg_URL %>" alt="listing image" 
               class="img-fluid rounded" style="max-height: 200px;">  <%-- ✅ responsive image --%>
        </div>

        <div class="mb-3">
          <label class="form-label">Upload New Image</label>
          <input type="file" name="listing[image]" class="form-control">
        </div>

        <div class="row">
          <div class="mb-3 col-6">  <%-- ✅ col-6 instead of col-md-4 --%>
            <label class="form-label">Price</label>
            <input type="text" name="listing[price]" required class="form-control" 
                   value="<%= listing.price %>">
            <div class="invalid-feedback">Price required</div>
          </div>
          <div class="mb-3 col-6">  <%-- ✅ col-6 instead of col-md-6 --%>
            <label class="form-label">Location</label>
            <input type="text" name="listing[location]" required class="form-control" 
                   value="<%= listing.location %>">
            <div class="invalid-feedback">Location is required</div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Country</label>
          <input type="text" name="listing[country]" required class="form-control" 
                 value="<%= listing.country %>">
          <div class="invalid-feedback">This field is required</div>
        </div>

        <button type="submit" class="btn btn-dark w-100 mb-3">Update</button>  <%-- ✅ full width on mobile --%>

      </form>
    </div>
  </div>
</div>