<% layout("/layout/boilerplate") %>
<style>
  .Filters {
    padding: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-left: 12px;
    align-items: center;
  }

  .listing {
    text-align: center;
    padding-right: 10px;
    flex-direction: column;
    opacity: 0.6;
    align-items: center;
    cursor: pointer;
    display: flex;
    gap: 6px;
  }

  .listing:hover, .listing.active {
    opacity: 1;
  }

  .tax-info {
    display: none;
  }

  .Toggle {
    border: 1px solid gray;
    align-items: center;
    border-radius: 10px;
    padding: 10px;
    width: auto;
    min-width: 180px;
    margin-left: auto;
  }

  .listing-card .card {
    border: none;
    border-radius: 12px;
    overflow: hidden;
  }

  .listing-card img {
    height: 12rem;
    object-fit: cover;
  }
</style>

<div class="Filters">
  <div class="listing" data-category="Trending">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
  </div>

  <div class="listing" data-category="Room">
    <i class="fa-solid fa-bed"></i>
    <p>Room</p>
  </div>

  <div class="listing" data-category="Iconic Cities">
    <i class="fa-solid fa-city"></i>
    <p>Iconic Cities</p>
  </div>

  <div class="listing" data-category="Mountain">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountain</p>
  </div>

  <div class="listing" data-category="Castle">
    <i class="fa-brands fa-fort-awesome"></i>
    <p>Castle</p>
  </div>

  <div class="listing" data-category="Amazing Pool">
    <i class="fa-solid fa-person-swimming"></i>
    <p>Amazing Pool</p>
  </div>

  <div class="Toggle">
    <div class="form-check form-switch form-check-reverse">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      />
      <label class="form-check-label" for="switchCheckDefault">
        Display Total After Taxes
      </label>
    </div>
  </div>
</div>

<div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 p-2">
  <% for(let listing of alllisting) { %>
  <div class="col listing-card">
    <a href="/listing/<%=listing._id%>" style="text-decoration: none; color: inherit">
      <div class="card h-100">
        <img
          src="<%=listing.image.url%>"
          class="card-img-top"
          alt="img"
        />
        <div class="card-body p-2">
          <p class="card-text mb-0">
            <b><%= listing.title %></b><br />
            &#8377;<%= (listing.price !== null && listing.price !== undefined) ? listing.price.toLocaleString("en-IN") : "N/A" %> /Day
            <i class="tax-info">&nbsp;+18% GST</i>
          </p>
        </div>
      </div>
    </a>
  </div>
  <% } %>
</div>

<script>
  var filters = document.querySelectorAll(".listing");
  var listingCards = document.querySelectorAll(".listing-card");

  filters.forEach(function(filter) {
    filter.addEventListener("click", function() {
      var category = filter.dataset.category;

      filters.forEach(function(f) {
        f.classList.remove("active");
      });
      filter.classList.add("active");

      listingCards.forEach(function(card) {
        if (category === "Trending" || card.dataset.category === category) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });
    });
  });

  var Taxswitch = document.getElementById("switchCheckDefault");
  Taxswitch.addEventListener("click", function() {
    var taxInfos = document.getElementsByClassName("tax-info");
    for (var i = 0; i < taxInfos.length; i++) {
      if (taxInfos[i].style.display !== "inline") {
        taxInfos[i].style.display = "inline";
      } else {
        taxInfos[i].style.display = "none";
      }
    }
  });
</script>